# Use Firestore for persistence (client SDK only). Set to "true" to use Firestore instead of localStorage.
# Requires Firebase project and Firestore database created.
NEXT_PUBLIC_USE_FIRESTORE=

# Freesound API (search & add sounds from freesound.org). Get a token: https://freesound.org/apiv2/apply
NEXT_PUBLIC_FREESOUND_API_KEY=

# Supabase (Auth with Google). Settings → API: Project URL + anon public key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
PIX_ID=