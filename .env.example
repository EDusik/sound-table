# Use Firestore for persistence (client SDK only). Set to "true" to use Firestore instead of localStorage.
# Requires Firebase project and Firestore database created.
NEXT_PUBLIC_USE_FIRESTORE=

# Freesound API (search & add sounds from freesound.org). Get a token: https://freesound.org/apiv2/apply
# Server-only — the key is never exposed to the client.
NEXT_PUBLIC_FREESOUND_API_KEY=

# Supabase (Auth with Google). Settings → API: Project URL + anon public key.
# SUPABASE_SERVICE_ROLE_KEY: same dashboard, "service_role" key — used by the app to create the "audios" bucket if missing (no manual Supabase setup).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Support: Stripe link is hardcoded in support page. Pix key (QR + copy) and optional Pix payment URL below.
NEXT_PUBLIC_PIX_ID=
# Optional: URL for Pix payment (e.g. Nubank cobrar link). QR code and "Pay with Pix" use this.
NEXT_PUBLIC_PIX_URL=
NEXT_PUBLIC_STRIPE_URL=